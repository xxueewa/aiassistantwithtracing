# Copy this file to .env and fill in real values for local testing.
# In AWS, these are stored in SSM Parameter Store (SecureString) and
# injected into Lambda at deploy time — never commit real secrets.

# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith  (https://smith.langchain.com → Settings → API Keys)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=langsmith-rag-demo
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Amazon OpenSearch Service
OPENSEARCH_ENDPOINT=search-langsmith-rag-dev-xxxxxx.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX=rag-documents

# AWS region (Lambda sets this automatically; needed for local runs)
AWS_REGION=us-east-1

# Models
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
